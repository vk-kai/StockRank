#西安2019-2025年二手房房价环比数据
"""
2025年11月份70个大中城市商品住宅销售价格变动情况
"""
huanbi = [99.9,99.8,101.2,100.9,100.6,100.6,100.1,100.0,99.4,99.3,99.2,99.4,# 2019年
          99.8,100.0,99.7,99.9,100.2,100.5,100.6,100.9,100.7,100.3,99.7,100.2,# 2020年
